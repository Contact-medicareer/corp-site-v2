---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="株式会社Contact｜医療職の才能を爆発させ、国を変える">
  <Header />
  <main class="min-h-screen">
    <section class="py-24 bg-gradient-to-b from-white to-[var(--color-surface-dim)]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p
          class="text-sm font-semibold tracking-widest text-[var(--color-medicareer-blue)] mb-4 uppercase"
        >
          Corporate Site v2
        </p>
        <h1
          class="text-5xl md:text-6xl font-bold mb-6 text-[var(--color-ink-navy)] leading-tight"
        >
          コーポレートサイト v2
        </h1>
        <p class="text-xl text-gray-700 mb-3">
          Astro 6 + TypeScript + Tailwind v4
        </p>
        <p class="text-sm text-gray-500 mb-12">
          構築中：v1（31ページ）と並行運用・段階的移行
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto mt-16">
          <div
            class="bg-white p-6 rounded-lg border border-[var(--color-outline-variant)] shadow-sm text-left"
          >
            <p
              class="text-xs font-semibold text-[var(--color-medicareer-blue)] mb-2 uppercase tracking-wider"
            >
              Phase 1
            </p>
            <h3 class="text-lg font-bold mb-2 text-[var(--color-ink-navy)]">
              基盤構築
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              Astro 6 + Tailwind v4 でセットアップ完了。3ページ稼働を目指す。
            </p>
          </div>
          <div
            class="bg-white p-6 rounded-lg border border-[var(--color-outline-variant)] shadow-sm text-left"
          >
            <p
              class="text-xs font-semibold text-[var(--color-medicareer-blue)] mb-2 uppercase tracking-wider"
            >
              Phase 2
            </p>
            <h3 class="text-lg font-bold mb-2 text-[var(--color-ink-navy)]">
              10ページ移植
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              v1 から優先度の高い10ページを Astro に移植。
            </p>
          </div>
          <div
            class="bg-white p-6 rounded-lg border border-[var(--color-outline-variant)] shadow-sm text-left"
          >
            <p
              class="text-xs font-semibold text-[var(--color-medicareer-blue)] mb-2 uppercase tracking-wider"
            >
              Phase 3
            </p>
            <h3 class="text-lg font-bold mb-2 text-[var(--color-ink-navy)]">
              完全移行
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              31ページ完全移行 + ニュース microCMS 化。
            </p>
          </div>
        </div>

        <div class="mt-16 inline-block bg-[var(--color-surface-container)] px-6 py-3 rounded-full">
          <p class="text-xs text-[var(--color-ink-navy)]">
            <span class="font-semibold">共通ヘッダー / フッター</span>
            で v1 の31ファイル重複問題を解決
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
