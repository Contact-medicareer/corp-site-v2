---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const types = [
  { icon: '💼', title: 'サービスについて', desc: 'メディキャリ大学／エージェント／コーチングなど各サービスへのご質問' },
  { icon: '🤝', title: '事業提携・協業', desc: '医療機関・教育機関・企業様からの提携ご相談' },
  { icon: '💰', title: '投資・資金調達', desc: '投資家様・VC様からのお問い合わせ' },
  { icon: '👥', title: '採用について', desc: '募集職種・カジュアル面談などの採用関連' },
  { icon: '📰', title: '取材・メディア', desc: 'メディアからの取材依頼・登壇依頼' },
  { icon: '✉️', title: 'その他', desc: '上記以外のお問い合わせ全般' },
];
---

<BaseLayout
  title="お問い合わせ｜株式会社Contact"
  description="株式会社Contactへのお問い合わせ。投資・提携・採用・取材・サービスに関するご相談をお受けしています。原則3営業日以内に返信いたします。"
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[var(--color-surface-dim)] py-16 md:py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <nav
          class="flex items-center gap-2 text-xs text-[var(--color-ink-muted)] mb-4 font-en"
          aria-label="Breadcrumb"
        >
          <a href="/" class="hover:text-[var(--color-revolution-red)] transition-colors">HOME</a>
          <span>›</span>
          <span class="text-[var(--color-ink-navy)]">お問い合わせ</span>
        </nav>
        <h1 class="text-4xl md:text-5xl font-bold text-[var(--color-ink-navy)] mb-3">
          お問い合わせ
        </h1>
        <p class="text-base text-[var(--color-ink-muted)]">
          投資 / 提携 / 採用 / 取材 / サービスについて — 原則3営業日以内に返信
        </p>
      </div>
    </section>

    <!-- お問い合わせ種別 -->
    <section class="py-20 md:py-24">
      <div class="mx-auto max-w-[1100px] px-6">
        <div class="text-center mb-12">
          <p
            class="text-sm tracking-[0.2em] uppercase text-[var(--color-revolution-red)] font-en mb-3"
          >
            Contact Types
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-ink-navy)] mb-3">
            お問い合わせ種別
          </h2>
          <p class="text-base text-[var(--color-ink-navy)]/80">
            該当するカテゴリを選んでフォームにご記入ください。
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
          {types.map((t) => (
            <div
              class="bg-[var(--color-surface-dim)] rounded-xl p-6 border border-[var(--color-outline-variant)] text-center"
            >
              <div class="text-4xl mb-3">{t.icon}</div>
              <h3 class="text-base font-bold text-[var(--color-ink-navy)] mb-2 leading-snug">
                {t.title}
              </h3>
              <p class="text-xs text-[var(--color-ink-navy)]/70 leading-relaxed">
                {t.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- フォーム -->
    <section class="bg-[var(--color-surface-dim)] py-20 md:py-24">
      <div class="mx-auto max-w-[800px] px-6">
        <div class="text-center mb-12">
          <p
            class="text-sm tracking-[0.2em] uppercase text-[var(--color-revolution-red)] font-en mb-3"
          >
            Contact Form
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-ink-navy)]">
            フォームから問い合わせる
          </h2>
        </div>

        <form
          class="bg-white rounded-2xl p-8 md:p-10 border border-[var(--color-outline-variant)] space-y-6"
          id="contactForm"
          action="https://formsubmit.co/7ff2e8c2bf35e27d821778a47d8e5797"
          method="POST"
        >
          <input type="hidden" name="_subject" value="【コーポレートサイト】お問い合わせを受信しました" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_next" id="formNext" value="" />
          <input
            type="hidden"
            name="_autoresponse"
            value="この度は株式会社Contactにお問い合わせいただき、誠にありがとうございます。

ご入力いただいた内容を確認し、原則3営業日以内に担当者よりご返信いたします。

恐れ入りますが、お急ぎの場合は本メールにご返信ください。

―――――
株式会社Contact
〒389-0102 長野県北佐久郡軽井沢町大字長倉2809-1
https://contact.ne.jp/
―――――

※本メールは自動送信です。"
          />
          <input type="text" name="_honey" style="display:none" />

          <div>
            <label class="block text-sm font-medium text-[var(--color-ink-navy)] mb-2">
              お問い合わせ種別
              <span class="ml-2 text-xs font-normal text-[var(--color-revolution-red)]">必須</span>
            </label>
            <select
              name="お問い合わせ種別"
              required
              class="w-full px-4 py-3 text-sm border border-[var(--color-outline-variant)] rounded-lg bg-white focus:outline-none focus:border-[var(--color-revolution-red)]"
            >
              <option value="">選択してください</option>
              <option>サービスについて</option>
              <option>事業提携・協業</option>
              <option>投資・資金調達</option>
              <option>採用について</option>
              <option>取材・メディア</option>
              <option>その他</option>
            </select>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-[var(--color-ink-navy)] mb-2">
                お名前
                <span class="ml-2 text-xs font-normal text-[var(--color-revolution-red)]">必須</span>
              </label>
              <input
                type="text"
                name="お名前"
                placeholder="例：依田 龍之介"
                required
                class="w-full px-4 py-3 text-sm border border-[var(--color-outline-variant)] rounded-lg bg-white focus:outline-none focus:border-[var(--color-revolution-red)]"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--color-ink-navy)] mb-2">
                所属（会社・団体名）
              </label>
              <input
                type="text"
                name="所属"
                placeholder="例：株式会社サンプル"
                class="w-full px-4 py-3 text-sm border border-[var(--color-outline-variant)] rounded-lg bg-white focus:outline-none focus:border-[var(--color-revolution-red)]"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-[var(--color-ink-navy)] mb-2">
                メールアドレス
                <span class="ml-2 text-xs font-normal text-[var(--color-revolution-red)]">必須</span>
              </label>
              <input
                type="email"
                name="email"
                placeholder="例：name@example.com"
                required
                class="w-full px-4 py-3 text-sm border border-[var(--color-outline-variant)] rounded-lg bg-white focus:outline-none focus:border-[var(--color-revolution-red)]"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--color-ink-navy)] mb-2">
                電話番号
              </label>
              <input
                type="tel"
                name="電話番号"
                placeholder="例：03-0000-0000"
                class="w-full px-4 py-3 text-sm border border-[var(--color-outline-variant)] rounded-lg bg-white focus:outline-none focus:border-[var(--color-revolution-red)]"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-[var(--color-ink-navy)] mb-2">
              お問い合わせ内容
              <span class="ml-2 text-xs font-normal text-[var(--color-revolution-red)]">必須</span>
            </label>
            <textarea
              name="お問い合わせ内容"
              placeholder="ご相談内容をご記入ください"
              required
              rows="6"
              class="w-full px-4 py-3 text-sm border border-[var(--color-outline-variant)] rounded-lg bg-white focus:outline-none focus:border-[var(--color-revolution-red)] resize-y"
            ></textarea>
          </div>

          <div>
            <label class="flex items-center gap-2 text-sm text-[var(--color-ink-navy)]/80 cursor-pointer">
              <input
                type="checkbox"
                name="プライバシーポリシー同意"
                value="同意済み"
                required
                class="w-4 h-4 text-[var(--color-revolution-red)]"
              />
              <a
                href="/privacy-policy/"
                target="_blank"
                rel="noopener"
                class="text-[var(--color-revolution-red)] underline"
              >プライバシーポリシー</a>
              に同意します
            </label>
          </div>

          <div class="text-center pt-4">
            <button
              type="submit"
              class="inline-flex items-center px-10 py-4 text-base font-medium text-white bg-[var(--color-revolution-red)] rounded-full hover:bg-[var(--color-revolution-red-dark)] transition-colors cursor-pointer border-0"
            >
              送信する
            </button>
            <p class="mt-4 text-xs text-[var(--color-ink-muted)]">
              ※ 送信後、原則3営業日以内に担当者よりご返信いたします。
            </p>
          </div>
        </form>
      </div>
    </section>

    <!-- 所在地 -->
    <section class="py-20 md:py-24">
      <div class="mx-auto max-w-[800px] px-6">
        <div class="text-center mb-12">
          <p
            class="text-sm tracking-[0.2em] uppercase text-[var(--color-revolution-red)] font-en mb-3"
          >
            Location
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-ink-navy)]">
            所在地
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div
            class="bg-[var(--color-surface-dim)] rounded-xl p-8 border border-[var(--color-outline-variant)] text-center"
          >
            <p class="text-xs tracking-[0.15em] uppercase text-[var(--color-revolution-red)] font-en mb-3">
              本社（軽井沢）
            </p>
            <p class="text-base text-[var(--color-ink-navy)] font-medium leading-relaxed mb-2">
              長野県北佐久郡軽井沢町<br />大字長倉2809-1
            </p>
            <p class="text-xs text-[var(--color-ink-muted)]">登記本所</p>
          </div>
          <div
            class="bg-[var(--color-surface-dim)] rounded-xl p-8 border border-[var(--color-outline-variant)] text-center"
          >
            <p class="text-xs tracking-[0.15em] uppercase text-[var(--color-revolution-red)] font-en mb-3">
              オフィス（東京）
            </p>
            <p class="text-base text-[var(--color-ink-navy)] font-medium leading-relaxed mb-2">
              東京都世田谷区下北沢
            </p>
            <p class="text-xs text-[var(--color-ink-muted)]">主な業務拠点</p>
          </div>
        </div>
        <p class="text-sm text-center text-[var(--color-ink-muted)] mt-12">
          迅速・丁寧な対応を心がけております。お気軽にお問い合わせください。
        </p>
      </div>
    </section>
  </main>

  <script is:inline>
    (function() {
      const form = document.getElementById('contactForm');
      if (!form) return;

      const GAS_URL = 'https://script.google.com/macros/s/AKfycbxPTpvhr6QWX0zTmmtUMtpQEp3aan8p3ay0IqU09rdH1DAXnqxoLS6Lejslrl3DvgZn/exec';

      const nextInput = document.getElementById('formNext');
      if (nextInput) {
        const currentPath = window.location.pathname.replace(/\/$/, '');
        nextInput.value = window.location.origin + currentPath + '/thanks/';
      }

      let submitting = false;

      form.addEventListener('submit', function(e) {
        if (submitting) return;
        submitting = true;
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = '送信中...';
        }

        const formData = new FormData(form);
        formData.append('_source', 'contact-corporate-v2');

        fetch(GAS_URL, {
          method: 'POST',
          mode: 'no-cors',
          body: formData
        }).catch(function(err) {
          console.error('GAS送信エラー（メール通知は継続）:', err);
        }).finally(function() {
          form.submit();
        });
      });
    })();
  </script>

  <Footer />
</BaseLayout>
