        </p>
      </div>

      <!-- 事業 -->
      <div>
        <h4 class="text-sm font-medium mb-3 text-white/90">事業</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li>
            <a href="/business/" class="hover:text-white transition-colors">事業内容</a>
          </li>
          <li>
            <a
              href="https://medicareer-brand-v1.vercel.app/"
              target="_blank"
              rel="noopener"
              class="hover:text-white transition-colors"
            >
              メディキャリ ブランド
            </a>
          </li>
          <li>
            <a
              href="https://lp-winova.jp/ct/lp02a/001/"
              target="_blank"
              rel="noopener"
              class="hover:text-white transition-colors"
            >
              メディキャリ大学
            </a>
          </li>
          <li>
            <a
              href="https://medicareer-agent-lp.vercel.app/"
              target="_blank"
