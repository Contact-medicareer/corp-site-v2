---
// Footer — 共通フッター（v1 由来：contact-corp-site-v1/src/index.html 214〜262行）
// 設計：ダーク背景 (ink-navy) + 4列グリッド
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ink-navy)] text-white">
  <div class="mx-auto max-w-[1200px] px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">
      <!-- ブランド -->
