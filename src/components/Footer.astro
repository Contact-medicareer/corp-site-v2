        <h4 class="text-sm font-medium mb-3 text-white/90">会社情報</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li>
            <a href="/about/" class="hover:text-white transition-colors">私たちについて</a>
          </li>
          <li>
            <a href="/about/mission/" class="hover:text-white transition-colors">ミッション</a>
          </li>
          <li>
            <a href="/about/members/" class="hover:text-white transition-colors">メンバー</a>
          </li>
          <li>
            <a href="/about/company/" class="hover:text-white transition-colors">会社概要</a>
          </li>
          <li>
            <a href="/news/" class="hover:text-white transition-colors">ニュース</a>
          </li>
          <li>
            <a href="/recruit/" class="hover:text-white transition-colors">採用情報</a>
          </li>
          <li>
            <a href="/contact/" class="hover:text-white transition-colors">お問い合わせ</a>
          </li>
        </ul>
