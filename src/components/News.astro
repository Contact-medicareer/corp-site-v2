---
// News セクション — 最新ニュース3件（v1 由来：contact-corp-site-v1/src/index.html 158〜186行）
// 設計：surface-dim 背景 + 縦リスト
const items = [
  {
    date: '2025.10.21',
    category: 'セミナー',
    categoryClass:
      'bg-[var(--color-coral)]/10 text-[var(--color-coral)] border-[var(--color-coral)]/30',
    href: '/news/2025-10-21-shinshu-open-innovation-forum/',
    title: '信州オープンイノベーションフォーラムに登壇しました',
  },
  {
    date: '2025.09.05',
    category: 'NEWS',
    categoryClass:
      'bg-[var(--color-medicareer-blue)]/10 text-[var(--color-medicareer-blue)] border-[var(--color-medicareer-blue)]/30',
    href: '/news/2025-09-05-startup-ecosystem-kickoff/',
    title:
      '株式会社Contact、内閣府選定「スタートアップ・エコシステム拠点都市」キックオフイベントに出席',
  },
  {
    date: '2024.09.24',
    category: 'NEWS',
    categoryClass:
      'bg-[var(--color-medicareer-blue)]/10 text-[var(--color-medicareer-blue)] border-[var(--color-medicareer-blue)]/30',
    href: '/news/2024-09-24-iryou-kigyou-startup-guide/',
    title: '9/24発売の『医療×起業 医師・医療者のためのスタートアップ起業ガイド』を一部執筆しました',
  },
];
---

<section id="news" class="bg-[var(--color-surface-dim)] py-24 md:py-32">
  <div class="mx-auto max-w-[1200px] px-6">
    <div
      class="flex items-center gap-3 mb-4 text-xs tracking-[0.18em] uppercase text-[var(--color-ink-muted)] font-en"
    >
      <span class="text-[var(--color-medicareer-blue)] font-medium font-en text-base">03</span>
      <span>News</span>
    </div>

    <h2
      class="text-3xl md:text-4xl lg:text-5xl text-[var(--color-ink-navy)] mb-12 leading-tight"
    >
      最新ニュース
    </h2>

    <ul class="max-w-[920px] mx-auto space-y-3 mb-10">
      {
        items.map((item) => (
          <li>
            <a
              href={item.href}
              class="flex flex-col md:flex-row md:items-center gap-3 md:gap-6 bg-white rounded-xl p-5 border border-[var(--color-outline-variant)] hover:border-[var(--color-medicareer-blue)] hover:shadow-sm transition-all"
            >
              <span class="text-sm text-[var(--color-ink-muted)] font-en md:w-24 shrink-0">
                {item.date}
              </span>
              <span
                class={`inline-flex items-center px-2.5 py-1 text-[11px] tracking-wider rounded-full border md:w-24 justify-center shrink-0 ${item.categoryClass}`}
              >
                {item.category}
              </span>
              <span class="text-sm md:text-base text-[var(--color-ink-navy)] leading-snug">
                {item.title}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="max-w-[920px] mx-auto text-right">
      <a
        href="/news/"
        class="text-sm font-medium text-[var(--color-medicareer-blue)] hover:gap-2 inline-flex items-center gap-1 transition-all"
      >
        ニュース一覧を見る <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
