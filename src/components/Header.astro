---
// Header — shared-components の BaseHeader を corp-v2 用 props で呼び出す薄いラッパー
// サイト固有の nav / CTA 設計はここで一元管理する
import BaseHeader from 'medicareer-shared-components/components/BaseHeader.astro';

const navItems = [
  { label: '私たちについて', href: '/about/' },
  { label: '事業', href: '#brands' },
  { label: 'AI', href: '/ai/' },
  { label: 'ニュース', href: '/news/' },
  { label: 'お問い合わせ', href: '/contact/' },
];

const cta = {
  label: '採用情報',
  href: '/recruit/',
  hoverBg: 'var(--color-revolution-red-dark)',
};
---

<BaseHeader
  logoSymbol="C"
  siteName="Contact"
  primaryColor="var(--color-revolution-red)"
  navItems={navItems}
  cta={cta}
/>
