---
// 共通ヘッダー — 1ファイル変更で全ページ反映（v1 で31ファイルに重複していた問題を解決）
---

<header class="bg-white border-b border-[var(--color-outline-variant)] sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <a
      href="/"
      class="text-2xl font-bold text-[var(--color-medicareer-blue)] hover:text-[var(--color-medicareer-blue-deep)] transition-colors"
    >
      Contact
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a
        href="/about/"
        class="text-sm text-[var(--color-ink-navy)] hover:text-[var(--color-medicareer-blue)] transition-colors"
      >
        私たちについて
      </a>
      <a
        href="/business/"
        class="text-sm text-[var(--color-ink-navy)] hover:text-[var(--color-medicareer-blue)] transition-colors"
      >
        事業
      </a>
      <a
        href="/news/"
        class="text-sm text-[var(--color-ink-navy)] hover:text-[var(--color-medicareer-blue)] transition-colors"
      >
        ニュース
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-[var(--color-medicareer-blue)] rounded-md hover:bg-[var(--color-medicareer-blue-deep)] transition-colors"
      >
        お問い合わせ
      </a>
    </nav>
  </div>
</header>
